# Clerk publishable key for the dev/staging/prod instance.
# Get from Clerk Dashboard → API Keys (the "Publishable key" — starts with `pk_test_` or `pk_live_`).
# Required: the app will throw at startup if this is missing.
VITE_CLERK_PUBLISHABLE_KEY=

# Sentry DSN for error and performance monitoring.
# Get from Sentry → Project Settings → Client Keys (DSN). Optional locally —
# the SDK no-ops when this is empty so dev doesn't spam Sentry.
VITE_SENTRY_DSN=
